@using mvc_server.Helpers;
@model IEnumerable<FileInfo>
@{
    ViewData["Title"] = "Index";
}

<div class="text-left">
    <h1 class="display-4">Index</h1>

</div>
<div class="justify-content-start">
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Modified</th>
                <th>Size</th>
            </tr>
        </thead>
        <tbody>

            @{
                int i = 0;
                foreach (var item in Model)
                {

                    <tr>
                        <td><a asp-controller="Api" asp-action="GetFile" asp-route-id="@i">@item.Name</a></td>
                        <td>@item.LastWriteTime</td>
                        <td>@(Utility.BytesToStringOptimized(item.Length))</td>

                    </tr>
                    i++;
                }
            }



        </tbody>
    </table>

    <form id="uploadForm" asp-controller="Streaming" asp-action="UploadFile" method="post" enctype="multipart/form-data"
        onsubmit="AJAXSubmit(this);return false;">
        <dl>
            <dt>
                <label for="file">File</label>
            </dt>
            <dd>
                <input id="file" type="file" name="file" />
            </dd>
        </dl>

        <input class="btn" type="submit" value="Upload" />

        <div style="margin-top:15px">
            <output form="uploadForm" name="result"></output>
        </div>
    </form>

    @section Scripts {
        <script>
            "use strict";

            async function AJAXSubmit(oFormElement) {
                const formData = new FormData(oFormElement);

                try {
                    const response = await fetch(oFormElement.action, {
                        method: 'POST',
                        headers: {
                            'RequestVerificationToken': getCookie('RequestVerificationToken')
                        },
                        body: formData
                    });

                    oFormElement.elements.namedItem("result").value =
                        'Result: ' + response.status + ' ' + response.statusText;
                } catch (error) {
                    console.error('Error:', error);
                }
            }

            function getCookie(name) {
                var value = "; " + document.cookie;
                var parts = value.split("; " + name + "=");
                if (parts.length == 2) return parts.pop().split(";").shift();
            }
        </script>
    }
</div>
