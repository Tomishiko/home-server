@using mvc_server.Helpers;
@model IEnumerable<FileInfo>
@{
    ViewData["Title"] = "Index";
}

<div class="text-left">
    <h1 class="display-4">Index</h1>

</div>
<cache enabled="true">
    <div class="justify-content-start">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Modified</th>
                    <th>Size</th>
                </tr>
            </thead>
            <tbody>

                @{
                    int i = 0;
                    foreach (var item in Model)
                    {

                        <tr>
                            <td><a asp-controller="Api" asp-action="GetFile" asp-route-id="@i">@item.Name</a></td>
                            <td>@item.LastWriteTime</td>
                            <td>@(Utility.BytesToStringOptimized(item.Length))</td>

                        </tr>
                        i++;
                    }
                }



            </tbody>
        </table>
    </div>
</cache>