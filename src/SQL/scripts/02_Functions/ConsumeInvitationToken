CREATE OR REPLACE FUNCTION consume_invitation_token(
    p_token_hash BYTEA,
    p_username VARCHAR(255),
    p_password VARCHAR(255),
    p_email VARCHAR(255)
)
RETURNS INT -- Returns the newly created user_id
LANGUAGE plpgsql
AS $$
DECLARE
    v_token_id INT;
    v_issuer_id BIGINT;
    v_new_user_id INT;
BEGIN
    SELECT id, issuer_id
    INTO v_token_id, v_issuer_id
    FROM invites
    WHERE token_hash = p_token_hash
      AND expires_at > now()
      AND used_at IS NULL
    FOR UPDATE;

    IF v_token_id IS NULL THEN
        RAISE EXCEPTION 'Token is invalid, expired, or already consumed.'
            USING ERRCODE = '02000';
    END IF;

    INSERT INTO users (uname,password,email,role_id)
    -- role id for default user is 1
    VALUES (p_username, p_password, p_email, 1)
    RETURNING id INTO v_new_user_id;

    UPDATE invites
    SET (used_at,used_by) = (now(),v_new_user_id)
    WHERE id = v_token_id;

    RETURN v_new_user_id;

END;
$$;
