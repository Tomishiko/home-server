@using System.Collections.Immutable;
@model ImmutableArray<core.Models.Log>

@for(int i = 0; i < Model.Length; i++) {
<tr>
    <td>@Model[i].Uname</td>
    <td>@Model[i].Event</td>
    <td>
        <time datetime="@Model[i].Time.ToString("O")">
            @Model[i].Time.ToString("g")
        </time>

    </td>
</tr>
}
