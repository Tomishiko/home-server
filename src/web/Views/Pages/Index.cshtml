@using web.Helpers;
@model IEnumerable<FileInfo>
    @{
    ViewData["Title"] = "Index";
    }
    @* TODO: #4 add antiforgery token for this page *@

    <div style="padding-top: 8px; padding-bottom: 16px;">
        <div class="row g-3">


            <div class="col-auto w-auto">
                <input class="form-control" type="file" id="file">
            </div>
            <div class="col-auto ">
                <button id="submitBtn" class="btn btn-dark border-secondary">Upload</button>
            </div>

        </div>
        <div class="progress" style="width: 320px;margin-top: 10px;">
            <div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" aria-valuenow="0"
                aria-valuemin="0" aria-valuemax="100" style="width: 0%"></div>

        </div>
    </div>
    <div class="container-list-group-horizontal" id="table-container">
        @await Html.PartialAsync("/Views/Partials/_IndexTable.cshtml", Model, ViewData)
    </div>
    <ul id="contextMenu" class="dropdown-menu" role="menu" style="display:none">
        <li><a id="print" class="dropdown-item" href="#">Print</a></li>
        <li><a id="download" class="dropdown-item" href="#">Download</a></li>
    </ul>
    @section Scripts {
    <script src="~/js/upload.js"></script>
    <script src="~/js/indexTable.js"></script>
    <script src="~/js/indexTableContextMenu.js"></script>
    }
