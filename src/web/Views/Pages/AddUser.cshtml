<style>
    #createBtn {
        --bs-btn-border-color: #19be72;
        --bs-btn-color: #19be72;
    }
</style>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header text-white">
                    <h4 class="mb-0">Register New User</h4>
                </div>
                <div class="card-body">
                    <form id="registerForm" name="signIn">
                        <div class="mb-3">
                            <label for="Uname" class="form-label">Username</label>
                            <input type="text" class="form-control" id="fullName" name="uname" required>
                        </div>

                        <div class="mb-3">
                            <label for="email" class="form-label">Email address</label>
                            <input type="email" class="form-control" id="email" name="email" required>
                        </div>

                        <div class="mb-3">
                            <label for="password" class="form-label">Password</label>
                            <input type="password" class="form-control" id="password" name="password" required>
                        </div>

                        <div class="mb-3">
                            <label for="role" class="form-label">Role</label>
                            <select class="form-select" id="role" name="role" required>
                                <option value="">-- Select Role --</option>
                                <option value="Admin">Admin</option>
                                <option value="User">User</option>
                            </select>
                        </div>

                        <button type="submit" id="createBtn" class="btn btn-dark btn-outline-success w-100">Create
                            Account</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts{
    <script type="module">
        import * as service from '/js/manage/NewUser.js'
        $('#registerForm').on('submit',async function(e){
                e.preventDefault();
                const form = document.forms.signIn;
                const selected = form.elements.role.selectedIndex;
                await service.NewUser(form.elements.uname.value,
                        form.elements.password.value,
                        form.elements.role.options[selected].value,
                        form.elements.email.value);

        });

    </script>
}
