<style>
    #createBtn {
        --bs-btn-border-color: #19be72;
        --bs-btn-color: #19be72;
    }
</style>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header text-white">
                    <h4 class="mb-0">Register New User</h4>
                </div>
                <div class="card-body">
                    <form id="registerForm" class="needs-validation" name="signIn" novalidate>
                        <div class="mb-3">
                            <label for="Uname" class="form-label">Username</label>
                            <input type="text" class="form-control" id="fullName" name="uname" pattern="^[a-zA-Z][a-zA-Z0-9_]{2,15}$" required>
                            <div class="invalid-feedback">Bad username</div>
                        </div>

                        <div class="mb-3">
                            <label for="email" class="form-label">Email address</label>
                            <input type="email" class="form-control" id="email" name="email">
                            <div class="invalid-feedback">Bad email format!</div>
                        </div>

                        <div class="mb-3">
                            <label for="password" class="form-label">Password</label>
                            <input type="password" class="form-control" id="password" name="password" required>
                            <div class="invalid-feedback">Password is required!</div>
                        </div>

                        <div class="mb-3">
                            <label for="role" class="form-label">Role</label>
                            <select class="form-select" id="role" name="role" required>
                                <option value="">-- Select Role --</option>
                                <option value="Admin">Admin</option>
                                <option value="User">User</option>
                            </select>
                            <div class="invalid-feedback">Role is required!</div>
                        </div>

                        <button type="submit" id="createBtn" class="btn btn-dark btn-outline-success w-100">Create
                            Account</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts{
<script type="module">
    import * as userService from '/js/manage/NewUser.js'
    $('#registerForm').on('submit', async function (e) {
        e.preventDefault();
        e.stopPropagation();
        const form = document.forms.signIn;
        const uname = form.elements.uname.value;
        if (form.checkValidity()) {
            const selected = form.elements.role.selectedIndex;
            await userService.NewUser(uname,
                form.elements.password.value,
                form.elements.role.options[selected].value,
                form.elements.email.value);
        }
        form.classList.add("was-validated");

    });

</script>
}
