@using core.Models
@using web.Controllers
@model IAsyncEnumerable<UserDto>

<div class="manager-container" data-module="manager">
    <button id="transparent-button" class="btn btn-dark border-secondary p-2 d-lg-none sticky-top" type="button">
        ==
    </button>
    <div class="row">
        <aside class="col-lg-2 col-sm-1 text-nowrap" >
            <div class="glassy-offcanvas offcanvas-lg offcanvas-start " data-bs-backdrop="true" tabindex="-1"
                 id="offcanvasResponsive" aria-labelledby="offcanvasExampleLabel">
                <div class="offcanvas-header">
                    <h5 class="offcanvas-title" id="offcanvasExampleLabel">Menu</h5>
                    <button type="button" class="btn-close btn-close-white" id="closeOffcanvasBtn"
                            aria-label="Close"></button>
                </div>
                <!--offcanvas nabigation-->
                <div class="offcanvas-body ">
                    <nav id="sidebar" class="d-md-block sidebar">
                        <div class="position-sticky">
                            <ul class="nav nav-pills flex-column">
                                <li class="nav-item">
                                    <a id="sidebar-item" href="#" class="nav-link active" aria-current="page"
                                       data-bs-dismiss="offcanvas" data-bs-target="#offcanvasResponsive"
                                       hx-get='@Url.Action(nameof(UsersManagerController.PartialUsersTable), "UsersManager")'
                                       hx-target="#content" hx-swap="innerHTML">User Base</a>
                                </li>
                                <li class="nav-item">
                                    <a id="sidebar-item" href="#" class="nav-link" aria-current="page"
                                       data-bs-dismiss="offcanvas" data-bs-target="#offcanvasResponsive"
                                       hx-get='@Url.Action(nameof(LogsManagerController.PartialLogsPage), "LogsManager")'
                                       hx-target="#content" hx-swap="innerHTML">Logs</a>
                                </li>
                            </ul>
                        </div>
                    </nav>

                </div>
            </div>
        </aside>
        <!--Content-->
        <div id="content" class="col-lg-10 col-sm-12 flex-grow-1  align-self-start">
            @await Html.PartialAsync("_ManageUsers.cshtml", Model)
        </div>
        <!--Content-->

        <!--Modal dialog confirm delete-->
        <div class="modal fade" id="modalConfirm" tabindex="-1" role="dialog">
            <div class="modal-dialog modal-dialog-centered" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Confirm action</h5>
                    </div>
                    <div class="modal-body">
                        <p></p>
                    </div>
                    <div class="modal-footer">
                        <button type="button" id="confirm" hx-delete="" hx-target="#content" hx-swap="innerHTML"
                                class="btn btn-dark btn-outline-danger">Delete</button>
                        <button type="button" class="btn btn-dark btn-secondary"
                                data-dismiss="#modalConfirm">Close</button>
                    </div>
                </div>
            </div>
            <!--Modal dialog-->
        </div>
    </div>
</div>
