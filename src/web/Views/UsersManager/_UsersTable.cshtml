@using web.Controllers
@model IAsyncEnumerable<core.Models.UserDto>

<div class="table-responsive" id="usersTable">
    <table class="table table-bordered text-nowrap">
        <thead>
            <tr>
                <th>ID</th>
                <th>Username</th>
                <th>Role</th>
                <th>Email</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @await foreach (var user in Model)
            {
                <tr>
                    <td>@user.Id</td>
                    <td>@user.Username</td>
                    <td>@user.Role</td>
                    <td>@user.Email</td>
                    <td>
                        <a href="@Url.Action("Edit", "Manager", new { id = user.Id })"
                           class="btn btn-dark btn-outline-warning">Edit</a>
                        <a href=""
                           hx-delete="@Url.Action(nameof(UsersManagerController.DeleteUser), "UsersMasdanager", new { id = user.Id, uname = user.Username })"
                           hx-target="#usersTable" hx-swap="outerHTML"
                           hx-confirm="@($"Are you sure you want to delete {user.Username} and all private files associated with this user?")"
                           class="btn btn-delete btn-dark btn-outline-danger">Delete</a>

                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
