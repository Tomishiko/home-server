@using web.Controllers
@model RegisterManagerRequest

<div class="container mt-5" data-module="newUser">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header text-white">
                    <h4 class="mb-0">Register New User</h4>
                </div>
                <div class="card-body">
                    <form id="registerForm" class="needs-validation" name="signIn"
                          hx-post="@Url.Action(nameof(UsersManagerController.AddUser),"UsersManager")"
                          hx-swap="innerHtml" hx-target="#main">
                        <div class="mb-3">
                            <label  class="form-label">Username</label>
                            <input type="text" class="form-control" id="fullName" name="Username"
                                   pattern="^[a-zA-Z][a-zA-Z0-9_]{2,15}$" required asp-for="Username">
                            <span asp-validation-for="Username" class="validation-warn"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Email address</label>
                            <input type="email" class="form-control" id="email" name="Email" maxlength="254" asp-for="Email">
                            <span asp-validation-for="Email" class="validation-warn"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Password</label>
                            <input type="password" class="form-control" id="password" name="Password" required asp-for="Password">
                            <span asp-validation-for="Password" class="validation-warn"></span>
                        </div>

                        <div class="mb-3">
                            <label  class="form-label">Role</label>
                            <select class="form-select" id="role" name="Role" required asp-for="Role">
                                <option value="">-- Select Role --</option>
                                <option value="2">Manager</option>
                                <option value="1">User</option>
                            </select>
                            <span asp-validation-for="Role" class="validation-warn"></span>
                        </div>

                        @Html.AntiForgeryToken()

                        <button type="submit" id="createBtn" class="btn btn-dark btn-outline-success w-100">Create
                            Account</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
