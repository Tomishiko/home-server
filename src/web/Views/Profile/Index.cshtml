@model core.Models.UserDto;
<link src="/dist/bootstrap-icons.min.css"/>
<div class="card shadow-sm rounded-3 mb-3">
    <div class="card-body">
        <div class="row">
            <!-- Left column -->
            <div class="col-sm-3 text-center">

                <i class="bi bi-person-circle text-secondary"></i>
            </div>

            <!-- Right column -->
            <div class="col-sm-8">
                <div class="row mb-2">
                    <div class="col-4  fw-bold ">Username:</div>
                    <div class="col-8  ">@Model.Username</div>
                </div>
                <div class="row mb-2">
                    <div class="col-4  fw-bold text-nowrap">Email:</div>
                    <div class="col-8  ">@Model.Email</div>
                </div>
                <div class="row mb-2">
                    <div class="col-4  fw-bold text-nowrap">Role:</div>
                    <div class="col-8  ">@Model.Role</div>
                </div>
            </div>
            <div class="mt-3 row">
                <a href="@Url.Action(" Edit", "Profile")" class="btn btn-dark btn-outline-warning col-md"> Edit Profile
                </a>
                <a href='@Url.Action("Logout", "Profile")' class="btn btn-dark btn-outline-danger col-md"> Log out </a>
            </div>
        </div>
    </div>
</div>
