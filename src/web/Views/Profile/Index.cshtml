@model core.Models.ProfileViewModel;
<style>.btn{margin: 8px;}</style>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"/>

<div class="card shadow-sm rounded-3 mb-3">
    <div class="card-body">
        <div class="row">
            <!-- Left column -->
            <div class="col-md-3 text-center">

                <i class="bi bi-person-circle text-secondary" style="font-size: 5rem;"></i>
                <h5 class="mt-2">@Model.FullName</h5>
                <p class="text-muted">@Model.Username</p>
            </div>

            <!-- Right column -->
            <div class="col-md-8">
                <h4>About</h4>
                <p>@Model.Bio</p>

                <dl class="row">
                    <dt class="col-sm-3">Email</dt>
                    <dd class="col-sm-9">@Model.Email</dd>

                    <dt class="col-sm-3">Phone</dt>
                    <dd class="col-sm-9">@Model.Phone</dd>

                    <dt class="col-sm-3">Location</dt>
                    <dd class="col-sm-9">@Model.Location</dd>
                </dl>

            </div>
            <div class="mt-3 row">
                <a href="@Url.Action(" Edit", "Profile" )" class="btn btn-dark btn-outline-warning col-md"> Edit Profile </a>
                <a href='@Url.Action("Logout","Profile")' class="btn btn-dark btn-outline-danger col-md"> Log out </a>
            </div>
        </div>
    </div>
</div>
